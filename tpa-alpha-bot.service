[Unit]
Description=TPA Alpha Discord Bot
After=network.target tpa-backend.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/tpa-alpha-bot
Environment="PATH=/home/ubuntu/apps/tpa-alpha-bot/backend/venv/bin"
EnvironmentFile=/home/ubuntu/apps/tpa-alpha-bot/.env
ExecStart=/home/ubuntu/apps/tpa-alpha-bot/backend/venv/bin/python bot/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
