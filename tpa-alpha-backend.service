[Unit]
Description=TPA Alpha Backend API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/tpa-alpha/tpa-alpha-bot/backend
Environment="PATH=/var/www/tpa-alpha/tpa-alpha-bot/backend/venv/bin"
EnvironmentFile=/var/www/tpa-alpha/tpa-alpha-bot/backend/.env
ExecStart=/var/www/tpa-alpha/tpa-alpha-bot/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
