[Unit]
Description=TPA Alpha Backend API
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/apps/tpa-alpha-bot/backend
Environment="PATH=/home/ubuntu/apps/tpa-alpha-bot/backend/venv/bin"
EnvironmentFile=/home/ubuntu/apps/tpa-alpha-bot/.env
ExecStart=/home/ubuntu/apps/tpa-alpha-bot/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
